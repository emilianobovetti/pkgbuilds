pkgname=llama.cpp-cuda
pkgver=b9064
pkgrel=1
# latest commit (git rev-parse --short HEAD)
# https://github.com/ggml-org/llama.cpp/commits/b9064/
_commit_id=c84e6d6
# raw commit number (git rev-list --count HEAD)
# https://github.com/ggml-org/llama.cpp/blob/b9064/.github/workflows/build-cmake-pkg.yml#L31
_build_number=9064
pkgdesc="LLM inference in C/C++"
arch=(x86_64 armv7h aarch64)
url="https://github.com/ggerganov/llama.cpp"
license=(MIT)
depends=(
  cuda
  curl
  nvidia-utils
)
makedepends=(
  cmake
  ninja
  cudnn
)
optdepends=(
  "python-numpy: needed for convert_hf_to_gguf.py"
  "python-safetensors: needed for convert_hf_to_gguf.py"
  "python-sentencepiece: needed for convert_hf_to_gguf.py"
  "python-pytorch: needed for convert_hf_to_gguf.py"
  "python-transformers: needed for convert_hf_to_gguf.py"
  "python-gguf: needed for convert_hf_to_gguf.py"
)
provides=(llama.cpp)
conflicts=(llama.cpp libggml ggml)
backup=("etc/conf.d/llama.cpp")
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/ggml-org/llama.cpp/archive/refs/tags/${pkgver}.tar.gz")
sha256sums=('574936bb0eaacc916397539ba091246f5563e4afec56db4ca054cb7cf86bada2')

build() {
  cmake \
    -B build \
    -G Ninja \
    -S "${srcdir}/llama.cpp-${pkgver}" \
    --fresh \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_CUDA_HOST_COMPILER="${CUDAHOSTCXX:-/usr/bin/g++-15}" \
    -DCMAKE_INSTALL_PREFIX='/usr' \
    -DBUILD_SHARED_LIBS=ON \
    -DLLAMA_BUILD_TESTS=OFF \
    -DLLAMA_USE_SYSTEM_GGML=OFF \
    -DGGML_ALL_WARNINGS=OFF \
    -DGGML_ALL_WARNINGS_3RD_PARTY=OFF \
    -DGGML_BUILD_EXAMPLES=OFF \
    -DGGML_BUILD_TESTS=OFF \
    -DGGML_OPENMP=ON \
    -DGGML_LTO=ON \
    -DGGML_RPC=ON \
    -DGGML_CUDA=ON \
    -DGGML_CUDA_FA_ALL_QUANTS=ON \
    -DGGML_CUDNN=ON \
    -DGGML_CUDA_COMPRESSION_MODE=speed \
    -DLLAMA_BUILD_SERVER=ON \
    -DLLAMA_BUILD_COMMIT="${_commit_id}" \
    -DLLAMA_BUILD_NUMBER="${_build_number}" \
    -DLLAMA_OPENSSL=ON \
    -DGGML_NATIVE=ON \
    -Wno-dev

  cmake --build build
}

package() {
  DESTDIR="${pkgdir}" cmake --install build

  install -Dm644 \
    "${srcdir}/llama.cpp-${pkgver}/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
